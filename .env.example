# ── MTG Platform — environment variables ─────────────────────────────────────
# Copy this to .env and fill in the values for your machine.

# Port nginx listens on (accessible at http://localhost:<HOST_PORT>)
HOST_PORT=8080

# Comma-separated list of modules to enable.
# Available: art_library, deck_primer, collection_rec, deck_builder
# This controls the nav bar AND which Docker Compose profiles to start.
ENABLED_MODULES=art_library

# ── Art Library ───────────────────────────────────────────────────────────────
# Absolute path to the directory containing library.json and the art/ folder.
# This is the MTG_ART_LIBRARY env var used by the Python code.
ART_LIBRARY_HOST_PATH=/path/to/your/mtg-art-library

# Absolute path to the Real-ESRGAN binary (for upscaling).
# Leave blank or omit if you don't have it; upscaling will be unavailable.
# REALESRGAN_HOST_PATH=/path/to/realesrgan-ncnn-vulkan
